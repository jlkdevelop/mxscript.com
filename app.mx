// app.mx — mxscript.com
//
// The official website for MX Script, written entirely in MX Script.
// Every byte of HTML and CSS on this page is generated from .mx code.
//
// Run with:  mx run app.mx
// Visit:     http://localhost:8080

server {
  port: 8080
  host: "0.0.0.0"
}

// ─── Routes ──────────────────────────────────────────────────────────────────

get / {
  return html(landing_page())
}

get /status {
  return json({
    site: "mxscript.com",
    served_by: "MX Script",
    repo: "https://github.com/jlkdevelop/mxscript.com",
    language: "https://github.com/jlkdevelop/mxscript",
    founder: "Jassim Alkharafi",
    timestamp: now_iso()
  })
}

// ─── Page composition ────────────────────────────────────────────────────────

fn landing_page() {
  return join([
    "<!DOCTYPE html>",
    "<html lang='en'>",
    head_section(),
    "<body>",
    nav_bar(),
    "<main>",
    hero_section(),
    code_demo_section(),
    features_section(),
    dogfood_callout(),
    "</main>",
    footer_section(),
    "</body>",
    "</html>"
  ], "\n")
}

fn head_section() {
  return join([
    "<head>",
    "  <meta charset='utf-8'>",
    "  <meta name='viewport' content='width=device-width, initial-scale=1'>",
    "  <title>MX Script — modern scripting for web apps and APIs</title>",
    "  <meta name='description' content='MX Script is a modern, open-source scripting language for building web apps and APIs. One file. Zero boilerplate.'>",
    "  <meta name='theme-color' content='#0a0a0a'>",
    "  <style>" + styles() + "</style>",
    "</head>"
  ], "\n")
}

fn nav_bar() {
  return join([
    "<nav class='nav'>",
    "  <a href='/' class='brand'>",
    "    <span class='mark'>{ }</span>",
    "    <span class='brand-name'>MX Script</span>",
    "  </a>",
    "  <div class='nav-links'>",
    "    <a href='https://github.com/jlkdevelop/mxscript#getting-started'>Docs</a>",
    "    <a href='https://github.com/jlkdevelop/mxscript'>GitHub</a>",
    "  </div>",
    "</nav>"
  ], "\n")
}

fn hero_section() {
  return join([
    "<section class='hero'>",
    "  <p class='eyebrow'>v0.8.0 · MIT licensed</p>",
    "  <h1>Modern scripting<br>for the web.</h1>",
    "  <p class='lede'>MX Script is a tiny, opinionated language for building web apps and APIs. One file. Zero boilerplate. Batteries included.</p>",
    "  <div class='install'>",
    "    <code><span class='prompt'>$</span> go install github.com/jlkdevelop/mxscript@latest</code>",
    "  </div>",
    "  <div class='cta'>",
    "    <a class='btn primary' href='https://github.com/jlkdevelop/mxscript#getting-started'>Get started →</a>",
    "    <a class='btn ghost' href='https://github.com/jlkdevelop/mxscript'>View on GitHub</a>",
    "  </div>",
    "</section>"
  ], "\n")
}

fn code_demo_section() {
  let sample = join([
    "server { port: 8080 }",
    "",
    "let users = [",
    "  { id: 1, name: \"Ada Lovelace\" },",
    "  { id: 2, name: \"Alan Turing\"  }",
    "]",
    "",
    "get /users/:id {",
    "  let id = num(request.params.id)",
    "  let user = find(users, fn(u) { return u.id == id })",
    "  if (user == null) {",
    "    return status(404, { error: \"not found\" })",
    "  }",
    "  return json(user)",
    "}"
  ], "\n")
  return join([
    "<section class='demo'>",
    "  <p class='section-label'>An entire JSON API. One file.</p>",
    "  <pre class='code'><code>" + sample + "</code></pre>",
    "</section>"
  ], "\n")
}

fn features_section() {
  let items = [
    { title: "HTTP routes",   body: "First-class GET / POST / PUT / DELETE / PATCH with path params, query, headers, and JSON body." },
    { title: "Middleware",    body: "Compose request pipelines with the use keyword. Auth, logging, CORS — write it once, reuse everywhere." },
    { title: "Sessions + JWT",body: "Signed cookies, JWT (HS256), HMAC, and SHA-256 built in. No npm install dance." },
    { title: "AI built in",   body: "ai.complete and ai.embed work out of the box with any OpenAI-compatible endpoint." },
    { title: "File I/O",      body: "read_file, write_file, list_files. Static asset serving via the static directive." },
    { title: "Zero deps",     body: "One Go binary. No node_modules. No package.json. No build step. Run a .mx file and ship." }
  ]
  let cards = map(items, fn(f) { return feature_card(f.title, f.body) })
  return join([
    "<section class='features'>",
    "  <p class='section-label'>What's in the box</p>",
    "  <div class='grid'>",
    join(cards, "\n"),
    "  </div>",
    "</section>"
  ], "\n")
}

fn feature_card(title, body) {
  return join([
    "    <div class='card'>",
    "      <h3>" + title + "</h3>",
    "      <p>" + body + "</p>",
    "    </div>"
  ], "\n")
}

fn dogfood_callout() {
  return join([
    "<section class='dogfood'>",
    "  <p class='section-label'>Meta moment</p>",
    "  <h2>This site is built in MX Script.</h2>",
    "  <p>Every page, every route, every byte of HTML you're reading was generated by an .mx file. The site grows in parallel with the language — every missing capability becomes the next feature.</p>",
    "  <a class='link-arrow' href='https://github.com/jlkdevelop/mxscript.com'>Read the source →</a>",
    "</section>"
  ], "\n")
}

fn footer_section() {
  return join([
    "<footer class='footer'>",
    "  <p>Founded by <a href='https://github.com/jlkdevelop'>Jassim Alkharafi</a>. MIT licensed and built in the open.</p>",
    "</footer>"
  ], "\n")
}

// ─── Styles ──────────────────────────────────────────────────────────────────

fn styles() {
  return join([
    "*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }",
    "html { -webkit-text-size-adjust: 100%; }",
    "body {",
    "  background: #0a0a0a;",
    "  color: #fafafa;",
    "  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;",
    "  font-size: 16px;",
    "  line-height: 1.6;",
    "  -webkit-font-smoothing: antialiased;",
    "  text-rendering: optimizeLegibility;",
    "}",
    "a { color: inherit; text-decoration: none; }",
    "a:hover { color: #00ff88; }",
    "code, pre { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }",

    // Layout
    "main { max-width: 720px; margin: 0 auto; padding: 0 24px; }",
    "section { padding: 64px 0; border-top: 1px solid #161616; }",
    "section:first-child { border-top: none; padding-top: 80px; }",

    // Nav
    ".nav {",
    "  max-width: 720px; margin: 0 auto;",
    "  padding: 24px;",
    "  display: flex; align-items: center; justify-content: space-between;",
    "}",
    ".brand { display: flex; align-items: center; gap: 10px; font-weight: 600; }",
    ".brand:hover { color: #fafafa; }",
    ".mark {",
    "  display: inline-flex; align-items: center; justify-content: center;",
    "  width: 28px; height: 28px;",
    "  background: #00ff88; color: #0a0a0a;",
    "  border-radius: 6px;",
    "  font-family: ui-monospace, monospace; font-weight: 700; font-size: 13px;",
    "}",
    ".brand-name { letter-spacing: -0.01em; }",
    ".nav-links { display: flex; gap: 24px; font-size: 14px; color: #888; }",

    // Hero
    ".eyebrow {",
    "  display: inline-block;",
    "  font-family: ui-monospace, monospace; font-size: 12px;",
    "  color: #00ff88;",
    "  background: rgba(0, 255, 136, 0.08);",
    "  padding: 4px 10px; border-radius: 999px;",
    "  margin-bottom: 24px;",
    "}",
    ".hero h1 {",
    "  font-size: 56px; line-height: 1.05; letter-spacing: -0.03em;",
    "  font-weight: 700; margin-bottom: 20px;",
    "}",
    ".lede { font-size: 18px; color: #b0b0b0; max-width: 560px; margin-bottom: 32px; }",
    ".install {",
    "  background: #111; border: 1px solid #1f1f1f; border-radius: 10px;",
    "  padding: 14px 18px; margin-bottom: 24px;",
    "  font-size: 14px; overflow-x: auto;",
    "}",
    ".install code { color: #fafafa; }",
    ".install .prompt { color: #00ff88; margin-right: 10px; user-select: none; }",
    ".cta { display: flex; gap: 12px; flex-wrap: wrap; }",
    ".btn {",
    "  display: inline-flex; align-items: center;",
    "  padding: 10px 18px; border-radius: 8px;",
    "  font-size: 14px; font-weight: 500;",
    "  transition: transform 80ms ease, background 120ms ease;",
    "}",
    ".btn:hover { transform: translateY(-1px); }",
    ".btn.primary { background: #00ff88; color: #0a0a0a; }",
    ".btn.primary:hover { background: #33ffa1; color: #0a0a0a; }",
    ".btn.ghost { background: transparent; color: #fafafa; border: 1px solid #2a2a2a; }",
    ".btn.ghost:hover { border-color: #00ff88; color: #00ff88; }",

    // Section labels
    ".section-label {",
    "  font-family: ui-monospace, monospace; font-size: 12px;",
    "  color: #666; text-transform: uppercase; letter-spacing: 0.08em;",
    "  margin-bottom: 20px;",
    "}",

    // Code block
    ".code {",
    "  background: #111; border: 1px solid #1f1f1f; border-radius: 10px;",
    "  padding: 24px; overflow-x: auto;",
    "  font-size: 13.5px; line-height: 1.7;",
    "}",
    ".code code { color: #e8e8e8; white-space: pre; }",

    // Features grid
    ".grid {",
    "  display: grid;",
    "  grid-template-columns: repeat(2, 1fr);",
    "  gap: 16px;",
    "}",
    ".card {",
    "  background: #0e0e0e; border: 1px solid #1a1a1a; border-radius: 10px;",
    "  padding: 22px;",
    "  transition: border-color 120ms ease;",
    "}",
    ".card:hover { border-color: #2a2a2a; }",
    ".card h3 {",
    "  font-size: 15px; font-weight: 600;",
    "  margin-bottom: 8px; color: #fafafa;",
    "}",
    ".card p { font-size: 14px; color: #888; line-height: 1.55; }",

    // Dogfood callout
    ".dogfood h2 {",
    "  font-size: 32px; line-height: 1.15; letter-spacing: -0.02em;",
    "  font-weight: 700; margin-bottom: 16px;",
    "}",
    ".dogfood p { color: #b0b0b0; max-width: 560px; margin-bottom: 24px; }",
    ".link-arrow { color: #00ff88; font-weight: 500; font-size: 14px; }",
    ".link-arrow:hover { text-decoration: underline; }",

    // Footer
    ".footer {",
    "  max-width: 720px; margin: 0 auto;",
    "  padding: 40px 24px 64px;",
    "  font-size: 13px; color: #666;",
    "}",
    ".footer a { color: #888; }",
    ".footer a:hover { color: #00ff88; }",

    // Responsive
    "@media (max-width: 600px) {",
    "  .hero h1 { font-size: 40px; }",
    "  .lede { font-size: 16px; }",
    "  .grid { grid-template-columns: 1fr; }",
    "  .dogfood h2 { font-size: 26px; }",
    "  section { padding: 48px 0; }",
    "}"
  ], "\n")
}
