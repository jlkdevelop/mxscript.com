    "      <h3>👋 Reach out</h3>",
    "      <p>Building something with MX Script? Want to collaborate? <a href='https://github.com/jlkdevelop'>Find me on GitHub</a> — I read every message.</p>",
    "      <span class='involved-cta'>github.com/jlkdevelop</span>",
    "    </a>",
    "  </div>",
    "</section>"
  ], "\n")
}

fn dogfood_callout() {
  return join([
    "<section class='dogfood'>",
    "  <p class='section-label'>Meta moment</p>",
    "  <h2>This site is built in MX Script.</h2>",
    "  <p>Every page, every route, every byte of HTML you're reading was generated by an .mx file. The site grows in parallel with the language — every missing capability becomes the next feature.</p>",
    "  <a class='link-arrow' href='https://github.com/jlkdevelop/mxscript.com'>Read the source →</a>",
    "</section>"
  ], "\n")
}

fn footer_section() {
  return join([
    "<footer class='footer'>",
    "  <p>Created by <a href='https://github.com/jlkdevelop'>Jassim Alkharafi</a>. MIT licensed and built in the open.</p>",
    "</footer>"
  ], "\n")
}

// ─── Styles ──────────────────────────────────────────────────────────────────
//
// Brand palette pulled from the MX Script logo:
//   blue   #2c46b0  — primary
//   yellow #f1b62e  — accent
//   ink    #0f172a  — body text
//   paper  #ffffff  — page background

fn styles() {
  return join([
    "*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }",
    "html { -webkit-text-size-adjust: 100%; }",
    "body {",
    "  background: #ffffff;",
    "  color: #0f172a;",
    "  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;",
    "  font-size: 16px;",
    "  line-height: 1.6;",
    "  -webkit-font-smoothing: antialiased;",
    "  text-rendering: optimizeLegibility;",
    "}",
    "a { color: #2c46b0; text-decoration: none; }",
    "a:hover { color: #1e3a8a; }",
    "code, pre { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }",

    // Layout
    "main { max-width: 760px; margin: 0 auto; padding: 0 24px; }",
    "section { padding: 72px 0; border-top: 1px solid #eef0f4; }",
    "section:first-child { border-top: none; padding-top: 56px; }",

    // Nav — logo anchored at the left edge of the content container,
    // links float to the right (Stripe / Vercel pattern)
    ".nav {",
    "  max-width: 760px; margin: 0 auto;",
    "  padding: 20px 24px;",
    "  display: flex; align-items: center; justify-content: space-between;",
    "}",
    ".brand { display: flex; align-items: center; gap: 12px; font-weight: 600; color: #0f172a; }",
    ".brand:hover { color: #0f172a; }",
    ".mark { width: 64px; height: 64px; display: block; object-fit: contain; }",
    ".brand-name { letter-spacing: -0.01em; font-size: 16px; }",
    ".nav-links { display: flex; align-items: center; gap: 22px; font-size: 14px; }",
    ".nav-links a { color: #475569; transition: color 100ms ease; }",
    ".nav-links a:hover { color: #2c46b0; }",

    // Hero
    ".eyebrow {",
    "  display: inline-block;",
    "  font-family: ui-monospace, monospace; font-size: 12px;",
    "  color: #2c46b0;",
    "  background: #eef2ff;",
    "  padding: 4px 12px; border-radius: 999px;",
    "  margin-bottom: 24px;",
    "  letter-spacing: 0.02em;",
    "}",
    ".hero h1 {",
    "  font-size: 56px; line-height: 1.05; letter-spacing: -0.03em;",
    "  font-weight: 700; margin-bottom: 20px; color: #0f172a;",
    "}",
    ".lede { font-size: 18px; color: #475569; max-width: 560px; margin-bottom: 32px; }",
    ".cta { display: flex; gap: 12px; flex-wrap: wrap; }",
    ".btn {",
    "  display: inline-flex; align-items: center;",
    "  padding: 11px 20px; border-radius: 8px;",
    "  font-size: 14px; font-weight: 500;",
    "  transition: transform 80ms ease, background 120ms ease, border-color 120ms ease;",
    "}",
    ".btn:hover { transform: translateY(-1px); }",
    ".btn.primary { background: #2c46b0; color: #ffffff; gap: 8px; }",
    ".btn.primary:hover { background: #1e3a8a; color: #ffffff; }",
    ".btn.primary .play { font-size: 11px; line-height: 1; opacity: 0.95; }",
    ".btn.secondary { background: #f1b62e; color: #0f172a; }",
    ".btn.secondary:hover { background: #ffc442; color: #0f172a; }",
    ".btn.ghost { background: #ffffff; color: #0f172a; border: 1px solid #d6dbe4; }",
    ".btn.ghost:hover { border-color: #2c46b0; color: #2c46b0; }",
    ".hero-meta { font-size: 13px; color: #64748b; margin-top: 18px; }",
    ".hero-meta a { color: #2c46b0; font-weight: 500; }",
    ".hero-meta a:hover { text-decoration: underline; }",

    // ─── Try-in-browser banner (top of page) ───────────────────────────────
    // Thin, flat, single-line announcement strip — references: Stripe's
    // 'product update' bar (~32px tall, dark-navy bg, single CTA), Vercel's
    // top notification (slim, mono accent label, no gradient), Linear's
    // changelog strip. Goal: present, not loud.
    ".try-banner {",
    "  display: flex; align-items: center; justify-content: center; gap: 10px;",
    "  padding: 7px 20px; min-height: 32px;",
    "  background: #2c46b0;",
    "  color: #ffffff;",
    "  font-size: 12.5px; font-weight: 500;",
    "  letter-spacing: 0.005em;",
    "  text-decoration: none;",
    "  border-bottom: 1px solid rgba(255,255,255,0.08);",
    "  transition: background 120ms ease;",
    "}",
    ".try-banner:hover { background: #1e3a8a; color: #ffffff; }",
    ".try-pill {",
    "  font-family: ui-monospace, monospace; font-size: 10px; font-weight: 700;",
    "  letter-spacing: 0.08em;",
    "  padding: 1px 6px; border-radius: 3px;",
    "  background: rgba(255,255,255,0.12); color: #ffffff;",
    "  text-transform: uppercase;",
    "}",
    ".try-text { color: rgba(255,255,255,0.85); }",
    ".try-cta { color: #ffffff; font-weight: 600; }",
    ".try-cta::after { content: ' →'; opacity: 0.85; }",

    // ─── Section heading (under .section-label) ────────────────────────────
    ".section-h {",
    "  font-size: 32px; line-height: 1.15; letter-spacing: -0.02em;",
    "  font-weight: 700; color: #0f172a; margin-bottom: 28px;",
    "}",

    // ─── Install section ───────────────────────────────────────────────────
    ".install { padding: 64px 0; }",
    ".os-tabs {",
    "  display: inline-flex; gap: 4px;",
    "  padding: 4px; margin-bottom: 18px;",
    "  background: #f1f5f9; border-radius: 10px;",
    "}",
    ".os-tab {",
    "  appearance: none; -webkit-appearance: none;",
    "  background: transparent; border: none; cursor: pointer;",
    "  padding: 7px 18px; border-radius: 7px;",
    "  font: inherit; font-size: 13.5px; font-weight: 500; color: #475569;",
    "  transition: background 100ms ease, color 100ms ease;",
    "}",
    ".os-tab:hover { color: #0f172a; }",
    ".os-tab.active {",
    "  background: #ffffff; color: #0f172a;",
    "  box-shadow: 0 1px 3px rgba(15,23,42,0.08);",
    "}",
    ".os-panel { margin-bottom: 4px; }",
    ".hidden { display: none !important; }",
    ".install-row {",
    "  display: flex; align-items: center; gap: 12px;",
    "  padding: 12px 14px; margin-bottom: 8px;",
    "  background: #ffffff; border: 1px solid #e2e8f0; border-radius: 10px;",
    "}",
    ".install-label {",
    "  flex: 0 0 auto; min-width: 80px;",
    "  font-family: ui-monospace, monospace; font-size: 11px; font-weight: 600;",
    "  color: #64748b; text-transform: uppercase; letter-spacing: 0.06em;",
    "}",
    ".install-cmd {",
    "  flex: 1 1 auto;",
    "  font-family: ui-monospace, monospace; font-size: 13px; color: #0f172a;",
    "  overflow-x: auto; white-space: nowrap;",
    "}",
    ".install-cmd .prompt { color: #94a3b8; user-select: none; margin-right: 8px; }",
    ".install-arch-group { flex: 1 1 auto; display: flex; flex-wrap: wrap; gap: 8px; }",
    ".arch-btn {",
    "  display: inline-flex; align-items: center;",
    "  padding: 6px 12px; border-radius: 7px;",
    "  background: #f1f5f9; color: #0f172a;",
    "  font-size: 13px; font-weight: 500;",
    "  transition: background 100ms ease;",
    "}",
    ".arch-btn:hover { background: #e2e8f0; color: #2c46b0; }",
    ".copy-btn {",
    "  flex: 0 0 auto;",
    "  appearance: none; -webkit-appearance: none;",
    "  background: #f1f5f9; border: 1px solid #e2e8f0; cursor: pointer;",
    "  padding: 5px 12px; border-radius: 6px;",
    "  font: inherit; font-size: 12px; font-weight: 600; color: #475569;",
    "  transition: background 100ms ease, color 100ms ease, border-color 100ms ease;",
    "}",
    ".copy-btn:hover { background: #ffffff; color: #2c46b0; border-color: #2c46b0; }",
    ".copy-btn.copied { background: #ecfdf5; color: #047857; border-color: #6ee7b7; }",
    ".install-divider {",
    "  display: flex; align-items: center; gap: 14px;",
    "  margin: 22px 0 14px;",
    "  font-size: 12px; color: #94a3b8;",
    "  text-transform: uppercase; letter-spacing: 0.08em;",
    "}",
    ".install-divider::before, .install-divider::after {",
    "  content: ''; flex: 1; height: 1px; background: #e2e8f0;",
    "}",
    ".install-foot { font-size: 13px; color: #64748b; margin-top: 18px; }",
    ".install-foot a { color: #2c46b0; font-weight: 500; }",
    ".install-foot a:hover { text-decoration: underline; }",
    ".install-foot code {",
    "  background: #f1f5f9; padding: 1px 6px; border-radius: 4px;",
    "  font-size: 12.5px; color: #0f172a;",
    "}",

    // ─── Channels grid ─────────────────────────────────────────────────────
    ".channels { padding: 64px 0; }",
    ".channel-grid {",
    "  display: grid;",
    "  grid-template-columns: repeat(2, 1fr);",
    "  gap: 16px;",
    "}",
    ".channel {",
    "  position: relative;",
    "  display: block;",
    "  padding: 20px 22px;",
    "  background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px;",
    "  color: #0f172a; text-decoration: none;",
    "  transition: border-color 120ms ease, transform 120ms ease;",
    "}",
    ".channel:hover { border-color: #2c46b0; color: #0f172a; transform: translateY(-1px); }",
    ".channel h3 { font-size: 15px; font-weight: 600; margin-bottom: 6px; }",
    ".channel p { font-size: 13.5px; color: #64748b; line-height: 1.55; padding-right: 24px; }",
    ".channel-arrow {",
    "  position: absolute; top: 18px; right: 18px;",
    "  color: #94a3b8; font-size: 16px;",
    "  transition: color 120ms ease, transform 120ms ease;",
    "}",
    ".channel:hover .channel-arrow { color: #2c46b0; transform: translateX(2px); }",

    // Section labels
    ".section-label {",
    "  font-family: ui-monospace, monospace; font-size: 12px;",
    "  color: #94a3b8; text-transform: uppercase; letter-spacing: 0.08em;",
    "  margin-bottom: 20px;",
    "}",

    // Code block
    ".code {",
    "  background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;",
    "  padding: 24px; overflow-x: auto;",
    "  font-size: 13.5px; line-height: 1.7;",
    "}",
    ".code code { color: #0f172a; white-space: pre; }",

    // Features grid
    ".grid {",
    "  display: grid;",
    "  grid-template-columns: repeat(2, 1fr);",
    "  gap: 16px;",
    "}",
    ".card {",
    "  background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px;",
    "  padding: 22px;",
    "  transition: border-color 120ms ease, box-shadow 120ms ease;",
    "}",
    ".card:hover { border-color: #2c46b0; box-shadow: 0 4px 16px rgba(44, 70, 176, 0.06); }",
    ".card h3 {",
    "  font-size: 15px; font-weight: 600;",
    "  margin-bottom: 8px; color: #0f172a;",
    "}",
    ".card p { font-size: 14px; color: #475569; line-height: 1.55; }",

    // Dogfood callout
    ".dogfood h2 {",
    "  font-size: 32px; line-height: 1.15; letter-spacing: -0.02em;",
    "  font-weight: 700; margin-bottom: 16px; color: #0f172a;",
    "}",
    ".dogfood p { color: #475569; max-width: 560px; margin-bottom: 24px; }",
    ".link-arrow { color: #2c46b0; font-weight: 500; font-size: 14px; }",
    ".link-arrow:hover { text-decoration: underline; }",

    // Footer
    ".footer {",
    "  max-width: 760px; margin: 0 auto;",
    "  padding: 40px 24px 64px;",
    "  font-size: 13px; color: #94a3b8;",
    "  border-top: 1px solid #eef0f4;",
    "}",
    ".footer a { color: #475569; }",
    ".footer a:hover { color: #2c46b0; }",

    // ─── About section ─────────────────────────────────────────────────────
    // References: Rust (rust-lang.org/about — principle cards), Go
    // (go.dev/about — logo + tabbed values), Swift (swift.org/about —
    // mission lead + paragraphs), Elixir (elixir-lang.org — logo
    // anchored hero + 'what makes it special' grid). Pattern: centered
    // logo+lead at top, principle cards in a row, then long-form prose
    // alongside a fact-sheet sidebar.
    ".about { padding: 80px 0 64px; }",
    ".about-hero { text-align: center; margin-bottom: 48px; }",
    ".about-logo {",
    "  width: 80px; height: 80px;",
    "  margin: 0 auto 16px;",
    "  display: block; object-fit: contain;",
    "}",
    ".about-label { color: #2c46b0; }",
    ".about-h {",
    "  font-size: 36px; line-height: 1.15; letter-spacing: -0.02em;",
    "  font-weight: 700; color: #0f172a; margin-bottom: 16px;",
    "}",
    ".about-lead {",
    "  font-size: 17px; line-height: 1.6; color: #475569;",
    "  max-width: 580px; margin: 0 auto;",
    "}",
    ".about-lead code {",
    "  background: #f1f5f9; padding: 1px 6px; border-radius: 4px;",
    "  font-size: 14.5px; color: #0f172a;",
    "}",

    // Principles grid
    ".principles {",
    "  display: grid;",
    "  grid-template-columns: repeat(3, 1fr);",
    "  gap: 16px; margin-bottom: 48px;",
    "}",
    ".principle {",
    "  position: relative;",
    "  padding: 24px 22px 22px;",
    "  background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px;",
    "  transition: border-color 120ms ease, transform 120ms ease, box-shadow 120ms ease;",
    "}",
    ".principle:hover { border-color: #2c46b0; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(44,70,176,0.08); }",
    ".principle-num {",
    "  display: inline-block;",
    "  font-family: ui-monospace, monospace; font-size: 11px; font-weight: 700;",
    "  color: #2c46b0; background: #eef2ff;",
    "  padding: 2px 8px; border-radius: 4px;",
    "  margin-bottom: 12px;",
    "  letter-spacing: 0.05em;",
    "}",
    ".principle h3 {",
    "  font-size: 16px; font-weight: 600; color: #0f172a;",
    "  margin-bottom: 8px;",
    "}",
    ".principle p { font-size: 14px; color: #64748b; line-height: 1.55; }",
    ".principle code {",
    "  background: #f1f5f9; padding: 1px 5px; border-radius: 3px;",
    "  font-size: 13px; color: #0f172a;",
    "}",

    // Sub-heading inside the prose column
    ".about-sub {",
    "  font-size: 18px; font-weight: 600; color: #0f172a;",
    "  margin-bottom: 16px;",
    "  padding-bottom: 10px;",
    "  border-bottom: 2px solid #f1b62e;",
    "  display: inline-block;",
    "}",

    ".about-grid {",
    "  display: grid;",
    "  grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);",
    "  gap: 32px; align-items: start;",
    "}",
    ".about-prose { font-size: 16px; line-height: 1.7; color: #334155; }",
    ".about-prose p { margin-bottom: 18px; }",
    ".about-prose p:last-child { margin-bottom: 0; }",
    ".about-prose a { color: #2c46b0; font-weight: 500; }",
    ".about-prose a:hover { text-decoration: underline; }",
    ".about-prose code {",
    "  background: #f1f5f9; padding: 1px 6px; border-radius: 4px;",
    "  font-size: 14px; color: #0f172a;",
    "}",
    ".about-prose em { color: #0f172a; font-style: normal; font-weight: 600; }",
    ".about-card {",
    "  padding: 22px;",
    "  background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;",
    "  position: sticky; top: 24px;",
    "}",
    ".about-meta { display: flex; flex-direction: column; gap: 12px; margin-bottom: 18px; }",
    ".about-row { display: flex; justify-content: space-between; align-items: center; gap: 12px; font-size: 13.5px; }",
    ".about-key { color: #94a3b8; font-family: ui-monospace, monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; }",
    ".about-val { color: #0f172a; font-weight: 500; text-align: right; }",
    ".about-val a { color: #2c46b0; }",
    ".about-val a:hover { text-decoration: underline; }",
    ".about-dot {",
    "  display: inline-block; width: 7px; height: 7px; border-radius: 50%;",
    "  background: #10b981; margin-right: 6px; vertical-align: middle;",
    "  box-shadow: 0 0 0 3px rgba(16,185,129,0.15);",
    "}",
    ".about-link {",
    "  display: inline-flex; align-items: center;",
    "  font-size: 13.5px; font-weight: 600; color: #2c46b0;",
    "  padding-top: 16px; border-top: 1px solid #e2e8f0;",
    "  width: 100%;",
    "}",
    ".about-link:hover { color: #1e3a8a; }",

    // ─── Section lead (used by Learn / Get Involved) ───────────────────────
    ".section-lead {",
    "  font-size: 17px; line-height: 1.6; color: #475569;",
    "  max-width: 620px; margin: 0 0 36px; ",
    "}",
    ".section-lead em { color: #0f172a; font-style: normal; font-weight: 600; }",

    // ─── Learn section ─────────────────────────────────────────────────────
    ".learn { padding: 64px 0; }",
    ".learn-label { color: #2c46b0; }",
    ".learn-grid {",
    "  display: grid;",
    "  grid-template-columns: repeat(3, 1fr);",
    "  gap: 16px; margin-bottom: 28px;",
    "}",
    ".learn-card {",
    "  display: block;",
    "  padding: 22px;",
    "  background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px;",
    "  color: #0f172a; text-decoration: none;",
    "  transition: border-color 120ms ease, transform 120ms ease, box-shadow 120ms ease;",
    "}",
    ".learn-card:hover { border-color: #2c46b0; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(44,70,176,0.08); color: #0f172a; }",
    ".learn-step {",
    "  display: inline-block;",
    "  font-family: ui-monospace, monospace; font-size: 11px; font-weight: 700;",
    "  color: #2c46b0; background: #eef2ff;",
    "  padding: 2px 8px; border-radius: 4px;",
    "  letter-spacing: 0.05em;",
    "  margin-bottom: 12px;",
    "}",
    ".learn-card h3 { font-size: 16px; font-weight: 600; color: #0f172a; margin-bottom: 8px; }",
    ".learn-card p { font-size: 14px; color: #64748b; line-height: 1.55; margin-bottom: 12px; }",
    ".learn-card p:last-child { margin-bottom: 0; }",
    ".learn-code {",
    "  background: #0f172a; color: #e8e8e8;",
    "  padding: 14px 16px; border-radius: 8px;",
    "  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;",
    "  font-size: 12.5px; line-height: 1.6;",
    "  overflow-x: auto;",
    "}",
    ".learn-list {",
    "  list-style: none; padding: 0; margin: 0;",
    "  display: flex; flex-direction: column; gap: 6px;",
    "}",
    ".learn-list li { font-size: 13px; color: #475569; }",
    ".learn-list code {",
    "  background: #f1f5f9; padding: 1px 6px; border-radius: 3px;",
    "  font-size: 12.5px; color: #0f172a; margin-right: 6px;",
    "}",
    ".learn-resources {",
    "  display: flex; flex-wrap: wrap; gap: 12px;",
    "  padding-top: 24px; border-top: 1px solid #e2e8f0;",
    "}",
    ".learn-resource {",
    "  display: inline-flex; align-items: center; gap: 4px;",
    "  font-size: 13.5px; font-weight: 500; color: #2c46b0;",
    "  padding: 6px 12px; border-radius: 7px;",
    "  background: #eef2ff;",
    "  transition: background 100ms ease;",
    "}",
    ".learn-resource:hover { background: #2c46b0; color: #ffffff; }",
    ".learn-resource .arr { font-weight: 400; }",

    // ─── Get Involved section ─────────────────────────────────────────────
    ".involved { padding: 64px 0; }",
    ".involved-label { color: #b45309; }",
    ".involved-grid {",
    "  display: grid;",
    "  grid-template-columns: repeat(3, 1fr);",
    "  gap: 16px;",
    "}",
    ".involved-card {",
    "  display: block;",
    "  padding: 22px;",
    "  background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px;",
    "  color: #0f172a; text-decoration: none;",
    "  transition: border-color 120ms ease, transform 120ms ease, box-shadow 120ms ease;",
    "}",
    ".involved-card:hover { border-color: #f1b62e; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(241,182,46,0.12); color: #0f172a; }",
    ".involved-card h3 { font-size: 16px; font-weight: 600; color: #0f172a; margin-bottom: 8px; }",
    ".involved-card p { font-size: 14px; color: #64748b; line-height: 1.55; margin-bottom: 12px; }",
    ".involved-card p a { color: #2c46b0; }",
    ".involved-cta {",
    "  display: inline-block;",
    "  font-family: ui-monospace, monospace; font-size: 12px; color: #2c46b0;",
    "  padding-top: 8px; border-top: 1px solid #f1f5f9;",
    "  width: 100%;",
    "}",

    // Responsive — tablet & small laptop
    "@media (max-width: 760px) {",
    "  main { padding: 0 20px; }",
    "  .nav { padding: 20px; }",
    "  .footer { padding: 36px 20px 56px; }",
    "  .hero h1 { font-size: 44px; }",
    "  .lede { font-size: 17px; }",
    "  .grid { grid-template-columns: 1fr; }",
    "  .dogfood h2 { font-size: 28px; }",
    "  section { padding: 56px 0; }",
    "  .nav { gap: 20px; padding: 16px 20px; }",
    "  .mark { width: 56px; height: 56px; }",
    "  .nav-links { gap: 18px; flex-wrap: wrap; justify-content: center; }",
    "  .code { padding: 20px; font-size: 13px; }",
    "  .about-grid { grid-template-columns: 1fr; gap: 24px; }",
    "  .about-card { position: static; }",
    "  .about { padding: 56px 0 48px; }",
    "  .about-hero { margin-bottom: 36px; }",
    "  .about-logo { width: 64px; height: 64px; margin-bottom: 14px; }",
    "  .about-h { font-size: 28px; }",
    "  .about-lead { font-size: 16px; }",
    "  .principles { grid-template-columns: 1fr; gap: 12px; margin-bottom: 36px; }",
    "  .principle { padding: 20px 18px; }",
    "  .learn-grid, .involved-grid { grid-template-columns: 1fr; gap: 12px; }",
    "  .learn, .involved { padding: 48px 0; }",
    "  .section-lead { font-size: 16px; }",
    "  .learn-resources { gap: 8px; }",
    "  .about, .install, .channels { padding: 48px 0; }",
    "}",

    // Tablet — install + channel grids stack
    "@media (max-width: 760px) {",
    "  .channel-grid { grid-template-columns: 1fr; }",
    "  .install-row { flex-wrap: wrap; gap: 8px; }",
    "  .install-cmd { flex: 1 1 100%; order: 3; }",
    "  .install-label { flex: 0 0 auto; }",
    "  .copy-btn { flex: 0 0 auto; order: 2; }",
    "  .section-h { font-size: 26px; }",
    "  .install, .channels { padding: 48px 0; }",
    "}",

    // Phone — narrow viewports
    "@media (max-width: 480px) {",
    "  body { font-size: 15px; }",
    "  main { padding: 0 16px; }",
    "  .nav {",
    "    padding: 14px 16px;",
    "    flex-direction: column; align-items: stretch; gap: 10px;",
    "  }",
    "  .brand { justify-content: center; }",
    "  .nav-links { justify-content: center; gap: 14px; font-size: 13px; }",
    "  .footer { padding: 32px 16px 48px; }",
    "  .brand-name { font-size: 15px; }",
    "  .mark { width: 52px; height: 52px; }",
    "  .hero h1 { font-size: 36px; line-height: 1.08; letter-spacing: -0.02em; }",
    "  .lede { font-size: 16px; }",
    "  .eyebrow { font-size: 11px; padding: 3px 10px; }",
    "  .cta { flex-direction: column; align-items: stretch; }",
    "  .btn { justify-content: center; padding: 13px 18px; }",
    "  section { padding: 44px 0; }",
    "  section:first-child { padding-top: 32px; }",
    "  .code { padding: 16px; font-size: 12.5px; line-height: 1.6; border-radius: 10px; }",
    "  .card { padding: 18px; }",
    "  .dogfood h2 { font-size: 24px; }",
    "  .try-banner { gap: 8px; padding: 6px 14px; font-size: 11.5px; min-height: 28px; }",
    "  .try-text { display: none; }",
    "  .install-arch-group { width: 100%; }",
    "  .arch-btn { flex: 1; justify-content: center; }",
    "  .install-foot { font-size: 12.5px; }",
    "  .about-card { padding: 18px; }",
    "}",

    // Tiny phones (iPhone SE etc.)
    "@media (max-width: 360px) {",
    "  .hero h1 { font-size: 32px; }",
    "  .nav-links { gap: 10px; font-size: 12.5px; }",
    "}"
  ], "\n")
}
