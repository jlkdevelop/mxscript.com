fn hero_section() {
  return join([
    "<section class='hero'>",
    "  <p class='eyebrow'>Open source · MIT licensed</p>",
    "  <h1>Lightweight scripting<br>for one-file web APIs.</h1>",
    "  <p class='lede'>MX Script is a lightweight scripting language for building one-file web APIs. Routes, JSON, JWT, sessions, SQL, AI — all first-class. No framework, no build step, no <code>node_modules</code>. <code>mx run app.mx</code> and you&rsquo;re shipping.</p>",
    "  <div class='cta'>",
    "    <a class='btn primary' href='https://try.mxscript.com'>",
    "      <span class='play'>▶</span> Try in your browser",
    "    </a>",
    "    <a class='btn secondary' href='#install'>Install</a>",
    "    <a class='btn ghost' href='https://github.com/jlkdevelop/mxscript'>GitHub</a>",
    "  </div>",
    "  <p class='hero-meta'>No install required for the playground · Live at <a href='https://try.mxscript.com'>try.mxscript.com</a></p>",
    "</section>"
  ], "\n")
}

fn code_demo_section() {
  let sample = join([
    "server { port: 8080 }",
    "let db = sql.open(\"./app.db\")",
    "sql.migrate(db, [\"CREATE TABLE IF NOT EXISTS links (code TEXT PRIMARY KEY, url TEXT, hits INT DEFAULT 0)\"])",
    "",
    "post /shorten {",
    "  let r = body_validate(request, {",
    "    type: \"object\", required: [\"url\"],",
    "    properties: { url: { type: \"string\", min_length: 8 } }",
    "  })",
    "  if (!r.ok) { return r.response }",
    "  let code = id.nanoid(7)",
    "  sql.insert(db, \"links\", { code: code, url: r.body.url, hits: 0 })",
    "  return status(201, { code: code, target: r.body.url })",
    "}",
    "",
    "get /:code {",
    "  let link = sql.find_one(db, \"links\", { code: request.params.code })",
    "  if (link == null) { return problem(404, \"Not found\") }",
    "  sql.update(db, \"links\", { hits: link.hits + 1 }, { code: link.code })",
    "  return redirect(link.url)",
    "}"
  ], "\n")
  return join([
    "<section class='demo'>",
    "  <p class='section-label'>A real URL shortener. One file.</p>",
    "  <pre class='code'><code>" + sample + "</code></pre>",
    "</section>"
  ], "\n")
}

fn features_section() {
  let items = [
    { title: "HTTP routes",   body: "First-class GET / POST / PUT / DELETE / PATCH with path params, query, headers, and JSON body." },
    { title: "Middleware",    body: "Compose request pipelines with the use keyword. Auth, logging, CORS — write it once, reuse everywhere." },
    { title: "Sessions + JWT",body: "Signed cookies, JWT (HS256), HMAC, and SHA-256 built in. No npm install dance." },
    { title: "AI built in",   body: "ai.complete and ai.embed work out of the box with any OpenAI-compatible endpoint." },
    { title: "File I/O",      body: "read_file, write_file, list_files. Static asset serving via the static directive." },
    { title: "Zero deps",     body: "One binary. No node_modules. No package.json. No build step. Run a .mx file and ship." }
  ]
  let cards = map(items, fn(f) { return feature_card(f.title, f.body) })
  return join([
    "<section class='features'>",
    "  <p class='section-label'>What's in the box</p>",
    "  <div class='grid'>",
    join(cards, "\n"),
    "  </div>",
    "</section>"
  ], "\n")
}

fn feature_card(title, body) {
  return join([
    "    <div class='card'>",
    "      <h3>" + title + "</h3>",
    "      <p>" + body + "</p>",
    "    </div>"
  ], "\n")
}

