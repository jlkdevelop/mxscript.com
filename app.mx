// app.mx — mxscript.com
//
// The official website for MX Script, written entirely in MX Script.
// Every byte of HTML and CSS on this page is generated from .mx code.
//
// Run with:  mx run app.mx
// Visit:     http://localhost:8080

server {
  port: 8080
  host: "0.0.0.0"
}

// ─── Brand assets (base64-inlined PNGs from the official MX logo) ───────────

let FAVICON_PNG = "data:image/png;base64,"
let LOGO_MARK_PNG = "data:image/png;base64,"

// ─── Routes ──────────────────────────────────────────────────────────────────

get / {
  return html(landing_page())
}

get /status {
  return json({
    site: "mxscript.com",
    served_by: "MX Script",
    repo: "https://github.com/jlkdevelop/mxscript.com",
    language: "https://github.com/jlkdevelop/mxscript",
    founder: "Jassim Alkharafi",
    timestamp: now_iso()
  })
}

// ─── Page composition ────────────────────────────────────────────────────────

fn landing_page() {
  return join([
    "<!DOCTYPE html>",
    "<html lang='en'>",
    head_section(),
    "<body>",
    try_banner(),
    nav_bar(),
    "<main>",
    hero_section(),
    code_demo_section(),
    install_section(),
    features_section(),
    channels_section(),
    dogfood_callout(),
    "</main>",
    footer_section(),
    runtime_script(),
    "</body>",
    "</html>"
  ], "\n")
}

fn head_section() {
  return join([
    "<head>",
    "  <meta charset='utf-8'>",
    "  <meta name='viewport' content='width=device-width, initial-scale=1'>",
    "  <title>MX Script — modern scripting for web apps and APIs</title>",
    "  <meta name='description' content='MX Script is a modern, open-source scripting language for building web apps and APIs. One file. Zero boilerplate.'>",
    "  <meta name='theme-color' content='#ffffff'>",
    "  <meta property='og:title' content='MX Script'>",
    "  <meta property='og:description' content='A modern open-source language for web apps and APIs. One file. Zero boilerplate.'>",
    "  <meta property='og:url' content='https://mxscript.com'>",
    "  <link rel='icon' type='image/png' href='" + FAVICON_PNG + "'>",
    "  <link rel='apple-touch-icon' href='" + LOGO_MARK_PNG + "'>",
    "  <style>" + styles() + "</style>",
    "</head>"
  ], "\n")
}

fn try_banner() {
  return join([
    "<a class='try-banner' href='https://try.mxscript.com' aria-label='Try MX Script in your browser'>",
    "  <span class='try-pill'>NEW</span>",
    "  <span class='try-text'>Run MX Script in your browser — no install, no signup.</span>",
    "  <span class='try-cta'>Open playground →</span>",
    "</a>"
  ], "\n")
}

fn nav_bar() {
  return join([
    "<nav class='nav'>",
    "  <a href='/' class='brand' aria-label='MX Script'>",
    "    <img class='mark' src='" + LOGO_MARK_PNG + "' alt='MX Script'>",
    "  </a>",
    "  <div class='nav-links'>",
    "    <a href='https://github.com/jlkdevelop/mxscript#getting-started'>Docs</a>",
    "    <a href='https://github.com/jlkdevelop/mxscript'>GitHub</a>",
    "    <a href='https://github.com/jlkdevelop/mxscript/releases'>Releases</a>",
    "  </div>",
    "</nav>"
  ], "\n")
}

fn hero_section() {
  return join([
    "<section class='hero'>",
    "  <p class='eyebrow'>Open source · MIT licensed</p>",
    "  <h1>Modern scripting<br>for the web.</h1>",
    "  <p class='lede'>MX Script is a tiny, opinionated language for building web apps and APIs. One file. Zero boilerplate. Batteries included — HTTP, JSON, JWT, sessions, SQL, AI tool calling.</p>",
    "  <div class='cta'>",
    "    <a class='btn primary' href='https://try.mxscript.com'>",
    "      <span class='play'>▶</span> Try in your browser",
    "    </a>",
    "    <a class='btn secondary' href='#install'>Install</a>",
    "    <a class='btn ghost' href='https://github.com/jlkdevelop/mxscript'>GitHub</a>",
    "  </div>",
    "  <p class='hero-meta'>No install required for the playground · Live at <a href='https://try.mxscript.com'>try.mxscript.com</a></p>",
    "</section>"
  ], "\n")
}

fn code_demo_section() {
  let sample = join([
    "server { port: 8080 }",
    "",
    "let users = [",
    "  { id: 1, name: \"Ada Lovelace\" },",
    "  { id: 2, name: \"Alan Turing\"  }",
    "]",
    "",
    "get /users/:id {",
    "  let id = num(request.params.id)",
    "  let user = find(users, fn(u) { return u.id == id })",
    "  if (user == null) {",
    "    return status(404, { error: \"not found\" })",
    "  }",
    "  return json(user)",
    "}"
  ], "\n")
  return join([
    "<section class='demo'>",
    "  <p class='section-label'>An entire JSON API. One file.</p>",
    "  <pre class='code'><code>" + sample + "</code></pre>",
    "</section>"
  ], "\n")
}

fn features_section() {
  let items = [
    { title: "HTTP routes",   body: "First-class GET / POST / PUT / DELETE / PATCH with path params, query, headers, and JSON body." },
    { title: "Middleware",    body: "Compose request pipelines with the use keyword. Auth, logging, CORS — write it once, reuse everywhere." },
    { title: "Sessions + JWT",body: "Signed cookies, JWT (HS256), HMAC, and SHA-256 built in. No npm install dance." },
    { title: "AI built in",   body: "ai.complete and ai.embed work out of the box with any OpenAI-compatible endpoint." },
    { title: "File I/O",      body: "read_file, write_file, list_files. Static asset serving via the static directive." },
    { title: "Zero deps",     body: "One binary. No node_modules. No package.json. No build step. Run a .mx file and ship." }
  ]
  let cards = map(items, fn(f) { return feature_card(f.title, f.body) })
  return join([
    "<section class='features'>",
    "  <p class='section-label'>What's in the box</p>",
    "  <div class='grid'>",
    join(cards, "\n"),
    "  </div>",
    "</section>"
  ], "\n")
}

fn feature_card(title, body) {
  return join([
    "    <div class='card'>",
    "      <h3>" + title + "</h3>",
    "      <p>" + body + "</p>",
    "    </div>"
  ], "\n")
}

fn install_section() {
  return join([
    "<section id='install' class='install'>",
    "  <p class='section-label'>Install</p>",
    "  <h2 class='section-h'>One command. Any platform.</h2>",
    "",
    "  <div class='os-tabs' role='tablist'>",
    "    <button class='os-tab' data-os='macos' role='tab' aria-selected='true'>macOS</button>",
    "    <button class='os-tab' data-os='linux' role='tab' aria-selected='false'>Linux</button>",
    "    <button class='os-tab' data-os='windows' role='tab' aria-selected='false'>Windows</button>",
    "  </div>",
    "",
    "  <div class='os-panel' data-os='macos'>",
    "    <div class='install-row'>",
    "      <span class='install-label'>Homebrew</span>",
    "      <code class='install-cmd'><span class='prompt'>$</span> brew install jlkdevelop/tap/mx</code>",
    "      <button class='copy-btn' data-copy='brew install jlkdevelop/tap/mx' aria-label='Copy command'>Copy</button>",
    "    </div>",
    "    <div class='install-row'>",
    "      <span class='install-label'>Direct</span>",
    "      <span class='install-arch-group'>",
    "        <a class='arch-btn' href='https://github.com/jlkdevelop/mxscript/releases/latest'>Apple Silicon (.tar.gz)</a>",
    "        <a class='arch-btn' href='https://github.com/jlkdevelop/mxscript/releases/latest'>Intel (.tar.gz)</a>",
    "      </span>",
    "    </div>",
    "  </div>",
    "",
    "  <div class='os-panel hidden' data-os='linux'>",
    "    <div class='install-row'>",
    "      <span class='install-label'>Homebrew</span>",
    "      <code class='install-cmd'><span class='prompt'>$</span> brew install jlkdevelop/tap/mx</code>",
    "      <button class='copy-btn' data-copy='brew install jlkdevelop/tap/mx' aria-label='Copy command'>Copy</button>",
    "    </div>",
    "    <div class='install-row'>",
    "      <span class='install-label'>Direct</span>",
    "      <span class='install-arch-group'>",
    "        <a class='arch-btn' href='https://github.com/jlkdevelop/mxscript/releases/latest'>arm64 (.tar.gz)</a>",
    "        <a class='arch-btn' href='https://github.com/jlkdevelop/mxscript/releases/latest'>amd64 (.tar.gz)</a>",
    "      </span>",
    "    </div>",
    "  </div>",
    "",
    "  <div class='os-panel hidden' data-os='windows'>",
    "    <div class='install-row'>",
    "      <span class='install-label'>Direct</span>",
    "      <span class='install-arch-group'>",
    "        <a class='arch-btn' href='https://github.com/jlkdevelop/mxscript/releases/latest'>arm64 (.zip)</a>",
    "        <a class='arch-btn' href='https://github.com/jlkdevelop/mxscript/releases/latest'>amd64 (.zip)</a>",
    "      </span>",
    "    </div>",
    "  </div>",
    "",
    "  <div class='install-divider'><span>or any platform with Go</span></div>",
    "",
    "  <div class='install-row'>",
    "    <span class='install-label'>Go</span>",
    "    <code class='install-cmd'><span class='prompt'>$</span> go install github.com/jlkdevelop/mxscript@latest</code>",
    "    <button class='copy-btn' data-copy='go install github.com/jlkdevelop/mxscript@latest' aria-label='Copy command'>Copy</button>",
    "  </div>",
    "",
    "  <p class='install-foot'>",
    "    After installing, run <code>mx --version</code> to confirm. Full docs at <a href='https://github.com/jlkdevelop/mxscript#getting-started'>github.com/jlkdevelop/mxscript</a>.",
    "  </p>",
    "</section>"
  ], "\n")
}

fn channels_section() {
  let channels = [
    { title: "Homebrew tap",      body: "brew install jlkdevelop/tap/mx — auto-bumped on every release.",                      href: "https://github.com/jlkdevelop/homebrew-tap" },
    { title: "VS Code Marketplace",body: "Syntax highlighting, snippets, and language server. Search 'MX Script' in extensions.", href: "https://marketplace.visualstudio.com/items?itemName=jlkdevelop.mxscript-lang" },
    { title: "GitHub Action",     body: "uses: jlkdevelop/setup-mx@v1 — drops the mx CLI onto Linux/macOS/Windows runners.",   href: "https://github.com/jlkdevelop/setup-mx" },
    { title: "Vercel",            body: "mx build --vercel emits a ready-to-deploy Go project. First-class Vercel support.",   href: "https://github.com/jlkdevelop/mxscript#deploy-to-vercel" }
  ]
  let cards = map(channels, fn(c) {
    return join([
      "    <a class='channel' href='" + c.href + "'>",
      "      <h3>" + c.title + "</h3>",
      "      <p>" + c.body + "</p>",
      "      <span class='channel-arrow'>→</span>",
      "    </a>"
    ], "\n")
  })
  return join([
    "<section class='channels'>",
    "  <p class='section-label'>Available everywhere</p>",
    "  <h2 class='section-h'>Pick the channel that fits your workflow.</h2>",
    "  <div class='channel-grid'>",
    join(cards, "\n"),
    "  </div>",
    "</section>"
  ], "\n")
}

fn runtime_script() {
  return join([
    "<script>",
    "(() => {",
    "  // ─ OS auto-detect for the install section.",
    "  const ua = navigator.userAgent || '';",
    "  let detected = 'macos';",
    "  if (/Win/i.test(ua)) detected = 'windows';",
    "  else if (/Linux|X11/i.test(ua) && !/Android/i.test(ua)) detected = 'linux';",
    "  else if (/Mac/i.test(ua) || /iPhone|iPad/i.test(ua)) detected = 'macos';",
    "  selectOS(detected);",
    "",
    "  document.querySelectorAll('.os-tab').forEach(btn => {",
    "    btn.addEventListener('click', () => selectOS(btn.dataset.os));",
    "  });",
    "  function selectOS(os) {",
    "    document.querySelectorAll('.os-tab').forEach(t => {",
    "      const on = t.dataset.os === os;",
    "      t.classList.toggle('active', on);",
    "      t.setAttribute('aria-selected', on ? 'true' : 'false');",
    "    });",
    "    document.querySelectorAll('.os-panel').forEach(p => {",
    "      p.classList.toggle('hidden', p.dataset.os !== os);",
    "    });",
    "  }",
    "",
    "  // ─ Copy-to-clipboard buttons.",
    "  document.querySelectorAll('.copy-btn').forEach(btn => {",
    "    btn.addEventListener('click', async () => {",
    "      try {",
    "        await navigator.clipboard.writeText(btn.dataset.copy);",
    "        const orig = btn.textContent;",
    "        btn.textContent = 'Copied';",
    "        btn.classList.add('copied');",
    "        setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1400);",
    "      } catch (e) { /* clipboard denied — user can still select manually */ }",
    "    });",
    "  });",
    "})();",
    "</script>"
  ], "\n")
}

fn dogfood_callout() {
  return join([
    "<section class='dogfood'>",
    "  <p class='section-label'>Meta moment</p>",
    "  <h2>This site is built in MX Script.</h2>",
    "  <p>Every page, every route, every byte of HTML you're reading was generated by an .mx file. The site grows in parallel with the language — every missing capability becomes the next feature.</p>",
    "  <a class='link-arrow' href='https://github.com/jlkdevelop/mxscript.com'>Read the source →</a>",
    "</section>"
  ], "\n")
}

fn footer_section() {
  return join([
    "<footer class='footer'>",
    "  <p>Founded by <a href='https://github.com/jlkdevelop'>Jassim Alkharafi</a>. MIT licensed and built in the open.</p>",
    "</footer>"
  ], "\n")
}

// ─── Styles ──────────────────────────────────────────────────────────────────
//
// Brand palette pulled from the MX Script logo:
//   blue   #2c46b0  — primary
//   yellow #f1b62e  — accent
//   ink    #0f172a  — body text
//   paper  #ffffff  — page background

fn styles() {
  return join([
    "*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }",
    "html { -webkit-text-size-adjust: 100%; }",
    "body {",
    "  background: #ffffff;",
    "  color: #0f172a;",
    "  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;",
    "  font-size: 16px;",
    "  line-height: 1.6;",
    "  -webkit-font-smoothing: antialiased;",
    "  text-rendering: optimizeLegibility;",
    "}",
    "a { color: #2c46b0; text-decoration: none; }",
    "a:hover { color: #1e3a8a; }",
    "code, pre { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }",

    // Layout
    "main { max-width: 760px; margin: 0 auto; padding: 0 24px; }",
    "section { padding: 72px 0; border-top: 1px solid #eef0f4; }",
    "section:first-child { border-top: none; padding-top: 56px; }",

    // Nav
    ".nav {",
    "  max-width: 760px; margin: 0 auto;",
    "  padding: 24px;",
    "  display: flex; align-items: center; justify-content: space-between;",
    "}",
    ".brand { display: flex; align-items: center; gap: 12px; font-weight: 600; color: #0f172a; }",
    ".brand:hover { color: #0f172a; }",
    ".mark { width: 32px; height: 32px; display: block; }",
    ".brand-name { letter-spacing: -0.01em; font-size: 16px; }",
    ".nav-links { display: flex; gap: 24px; font-size: 14px; }",
    ".nav-links a { color: #475569; }",
    ".nav-links a:hover { color: #2c46b0; }",

    // Hero
    ".eyebrow {",
    "  display: inline-block;",
    "  font-family: ui-monospace, monospace; font-size: 12px;",
    "  color: #2c46b0;",
    "  background: #eef2ff;",
    "  padding: 4px 12px; border-radius: 999px;",
    "  margin-bottom: 24px;",
    "  letter-spacing: 0.02em;",
    "}",
    ".hero h1 {",
    "  font-size: 56px; line-height: 1.05; letter-spacing: -0.03em;",
    "  font-weight: 700; margin-bottom: 20px; color: #0f172a;",
    "}",
    ".lede { font-size: 18px; color: #475569; max-width: 560px; margin-bottom: 32px; }",
    ".cta { display: flex; gap: 12px; flex-wrap: wrap; }",
    ".btn {",
    "  display: inline-flex; align-items: center;",
    "  padding: 11px 20px; border-radius: 8px;",
    "  font-size: 14px; font-weight: 500;",
    "  transition: transform 80ms ease, background 120ms ease, border-color 120ms ease;",
    "}",
    ".btn:hover { transform: translateY(-1px); }",
    ".btn.primary { background: #2c46b0; color: #ffffff; gap: 8px; }",
    ".btn.primary:hover { background: #1e3a8a; color: #ffffff; }",
    ".btn.primary .play { font-size: 11px; line-height: 1; opacity: 0.95; }",
    ".btn.secondary { background: #f1b62e; color: #0f172a; }",
    ".btn.secondary:hover { background: #ffc442; color: #0f172a; }",
    ".btn.ghost { background: #ffffff; color: #0f172a; border: 1px solid #d6dbe4; }",
    ".btn.ghost:hover { border-color: #2c46b0; color: #2c46b0; }",
    ".hero-meta { font-size: 13px; color: #64748b; margin-top: 18px; }",
    ".hero-meta a { color: #2c46b0; font-weight: 500; }",
    ".hero-meta a:hover { text-decoration: underline; }",

    // ─── Try-in-browser banner (top of page) ───────────────────────────────
    ".try-banner {",
    "  display: flex; align-items: center; justify-content: center; gap: 14px;",
    "  padding: 10px 24px;",
    "  background: linear-gradient(90deg, #2c46b0, #4661d8);",
    "  color: #ffffff;",
    "  font-size: 13.5px; font-weight: 500;",
    "  text-decoration: none;",
    "  transition: filter 100ms ease;",
    "}",
    ".try-banner:hover { filter: brightness(1.08); color: #ffffff; }",
    ".try-pill {",
    "  font-family: ui-monospace, monospace; font-size: 11px; font-weight: 700;",
    "  letter-spacing: 0.06em;",
    "  padding: 2px 8px; border-radius: 4px;",
    "  background: rgba(255,255,255,0.2); color: #ffffff;",
    "}",
    ".try-text { color: rgba(255,255,255,0.95); }",
    ".try-cta { color: #ffffff; font-weight: 600; }",

    // ─── Section heading (under .section-label) ────────────────────────────
    ".section-h {",
    "  font-size: 32px; line-height: 1.15; letter-spacing: -0.02em;",
    "  font-weight: 700; color: #0f172a; margin-bottom: 28px;",
    "}",

    // ─── Install section ───────────────────────────────────────────────────
    ".install { padding: 64px 0; }",
    ".os-tabs {",
    "  display: inline-flex; gap: 4px;",
    "  padding: 4px; margin-bottom: 18px;",
    "  background: #f1f5f9; border-radius: 10px;",
    "}",
    ".os-tab {",
    "  appearance: none; -webkit-appearance: none;",
    "  background: transparent; border: none; cursor: pointer;",
    "  padding: 7px 18px; border-radius: 7px;",
    "  font: inherit; font-size: 13.5px; font-weight: 500; color: #475569;",
    "  transition: background 100ms ease, color 100ms ease;",
    "}",
    ".os-tab:hover { color: #0f172a; }",
    ".os-tab.active {",
    "  background: #ffffff; color: #0f172a;",
    "  box-shadow: 0 1px 3px rgba(15,23,42,0.08);",
    "}",
    ".os-panel { margin-bottom: 4px; }",
    ".hidden { display: none !important; }",
    ".install-row {",
    "  display: flex; align-items: center; gap: 12px;",
    "  padding: 12px 14px; margin-bottom: 8px;",
    "  background: #ffffff; border: 1px solid #e2e8f0; border-radius: 10px;",
    "}",
    ".install-label {",
    "  flex: 0 0 auto; min-width: 80px;",
    "  font-family: ui-monospace, monospace; font-size: 11px; font-weight: 600;",
    "  color: #64748b; text-transform: uppercase; letter-spacing: 0.06em;",
    "}",
    ".install-cmd {",
    "  flex: 1 1 auto;",
    "  font-family: ui-monospace, monospace; font-size: 13px; color: #0f172a;",
    "  overflow-x: auto; white-space: nowrap;",
    "}",
    ".install-cmd .prompt { color: #94a3b8; user-select: none; margin-right: 8px; }",
    ".install-arch-group { flex: 1 1 auto; display: flex; flex-wrap: wrap; gap: 8px; }",
    ".arch-btn {",
    "  display: inline-flex; align-items: center;",
    "  padding: 6px 12px; border-radius: 7px;",
    "  background: #f1f5f9; color: #0f172a;",
    "  font-size: 13px; font-weight: 500;",
    "  transition: background 100ms ease;",
    "}",
    ".arch-btn:hover { background: #e2e8f0; color: #2c46b0; }",
    ".copy-btn {",
    "  flex: 0 0 auto;",
    "  appearance: none; -webkit-appearance: none;",
    "  background: #f1f5f9; border: 1px solid #e2e8f0; cursor: pointer;",
    "  padding: 5px 12px; border-radius: 6px;",
    "  font: inherit; font-size: 12px; font-weight: 600; color: #475569;",
    "  transition: background 100ms ease, color 100ms ease, border-color 100ms ease;",
    "}",
    ".copy-btn:hover { background: #ffffff; color: #2c46b0; border-color: #2c46b0; }",
    ".copy-btn.copied { background: #ecfdf5; color: #047857; border-color: #6ee7b7; }",
    ".install-divider {",
    "  display: flex; align-items: center; gap: 14px;",
    "  margin: 22px 0 14px;",
    "  font-size: 12px; color: #94a3b8;",
    "  text-transform: uppercase; letter-spacing: 0.08em;",
    "}",
    ".install-divider::before, .install-divider::after {",
    "  content: ''; flex: 1; height: 1px; background: #e2e8f0;",
    "}",
    ".install-foot { font-size: 13px; color: #64748b; margin-top: 18px; }",
    ".install-foot a { color: #2c46b0; font-weight: 500; }",
    ".install-foot a:hover { text-decoration: underline; }",
    ".install-foot code {",
    "  background: #f1f5f9; padding: 1px 6px; border-radius: 4px;",
    "  font-size: 12.5px; color: #0f172a;",
    "}",

    // ─── Channels grid ─────────────────────────────────────────────────────
    ".channels { padding: 64px 0; }",
    ".channel-grid {",
    "  display: grid;",
    "  grid-template-columns: repeat(2, 1fr);",
    "  gap: 16px;",
    "}",
    ".channel {",
    "  position: relative;",
    "  display: block;",
    "  padding: 20px 22px;",
    "  background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px;",
    "  color: #0f172a; text-decoration: none;",
    "  transition: border-color 120ms ease, transform 120ms ease;",
    "}",
    ".channel:hover { border-color: #2c46b0; color: #0f172a; transform: translateY(-1px); }",
    ".channel h3 { font-size: 15px; font-weight: 600; margin-bottom: 6px; }",
    ".channel p { font-size: 13.5px; color: #64748b; line-height: 1.55; padding-right: 24px; }",
    ".channel-arrow {",
    "  position: absolute; top: 18px; right: 18px;",
    "  color: #94a3b8; font-size: 16px;",
    "  transition: color 120ms ease, transform 120ms ease;",
    "}",
    ".channel:hover .channel-arrow { color: #2c46b0; transform: translateX(2px); }",

    // Section labels
    ".section-label {",
    "  font-family: ui-monospace, monospace; font-size: 12px;",
    "  color: #94a3b8; text-transform: uppercase; letter-spacing: 0.08em;",
    "  margin-bottom: 20px;",
    "}",

    // Code block
    ".code {",
    "  background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;",
    "  padding: 24px; overflow-x: auto;",
    "  font-size: 13.5px; line-height: 1.7;",
    "}",
    ".code code { color: #0f172a; white-space: pre; }",

    // Features grid
    ".grid {",
    "  display: grid;",
    "  grid-template-columns: repeat(2, 1fr);",
    "  gap: 16px;",
    "}",
    ".card {",
    "  background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px;",
    "  padding: 22px;",
    "  transition: border-color 120ms ease, box-shadow 120ms ease;",
    "}",
    ".card:hover { border-color: #2c46b0; box-shadow: 0 4px 16px rgba(44, 70, 176, 0.06); }",
    ".card h3 {",
    "  font-size: 15px; font-weight: 600;",
    "  margin-bottom: 8px; color: #0f172a;",
    "}",
    ".card p { font-size: 14px; color: #475569; line-height: 1.55; }",

    // Dogfood callout
    ".dogfood h2 {",
    "  font-size: 32px; line-height: 1.15; letter-spacing: -0.02em;",
    "  font-weight: 700; margin-bottom: 16px; color: #0f172a;",
    "}",
    ".dogfood p { color: #475569; max-width: 560px; margin-bottom: 24px; }",
    ".link-arrow { color: #2c46b0; font-weight: 500; font-size: 14px; }",
    ".link-arrow:hover { text-decoration: underline; }",

    // Footer
    ".footer {",
    "  max-width: 760px; margin: 0 auto;",
    "  padding: 40px 24px 64px;",
    "  font-size: 13px; color: #94a3b8;",
    "  border-top: 1px solid #eef0f4;",
    "}",
    ".footer a { color: #475569; }",
    ".footer a:hover { color: #2c46b0; }",

    // Responsive — tablet & small laptop
    "@media (max-width: 760px) {",
    "  main { padding: 0 20px; }",
    "  .nav { padding: 20px; }",
    "  .footer { padding: 36px 20px 56px; }",
    "  .hero h1 { font-size: 44px; }",
    "  .lede { font-size: 17px; }",
    "  .grid { grid-template-columns: 1fr; }",
    "  .dogfood h2 { font-size: 28px; }",
    "  section { padding: 56px 0; }",
    "  .nav-links { gap: 18px; }",
    "  .code { padding: 20px; font-size: 13px; }",
    "}",

    // Tablet — install + channel grids stack
    "@media (max-width: 760px) {",
    "  .channel-grid { grid-template-columns: 1fr; }",
    "  .install-row { flex-wrap: wrap; gap: 8px; }",
    "  .install-cmd { flex: 1 1 100%; order: 3; }",
    "  .install-label { flex: 0 0 auto; }",
    "  .copy-btn { flex: 0 0 auto; order: 2; }",
    "  .section-h { font-size: 26px; }",
    "  .install, .channels { padding: 48px 0; }",
    "}",

    // Phone — narrow viewports
    "@media (max-width: 480px) {",
    "  body { font-size: 15px; }",
    "  main { padding: 0 16px; }",
    "  .nav { padding: 16px; }",
    "  .footer { padding: 32px 16px 48px; }",
    "  .nav-links { gap: 14px; font-size: 13px; }",
    "  .brand-name { font-size: 15px; }",
    "  .mark { width: 28px; height: 28px; }",
    "  .hero h1 { font-size: 36px; line-height: 1.08; letter-spacing: -0.02em; }",
    "  .lede { font-size: 16px; }",
    "  .eyebrow { font-size: 11px; padding: 3px 10px; }",
    "  .cta { flex-direction: column; align-items: stretch; }",
    "  .btn { justify-content: center; padding: 13px 18px; }",
    "  section { padding: 44px 0; }",
    "  section:first-child { padding-top: 32px; }",
    "  .code { padding: 16px; font-size: 12.5px; line-height: 1.6; border-radius: 10px; }",
    "  .card { padding: 18px; }",
    "  .dogfood h2 { font-size: 24px; }",
    "  .try-banner { flex-direction: column; gap: 6px; padding: 10px 16px; font-size: 12.5px; text-align: center; }",
    "  .install-arch-group { width: 100%; }",
    "  .arch-btn { flex: 1; justify-content: center; }",
    "  .install-foot { font-size: 12.5px; }",
    "}",

    // Tiny phones (iPhone SE etc.)
    "@media (max-width: 360px) {",
    "  .hero h1 { font-size: 32px; }",
    "  .nav-links { gap: 12px; }",
    "  .nav-links a:nth-child(3) { display: none; }",
    "}"
  ], "\n")
}
