// app.mx — mxscript.com
//
// The official website for MX Script, written entirely in MX Script.
// Every byte of HTML and CSS on this page is generated from .mx code.
//
// Run with:  mx run app.mx
// Visit:     http://localhost:8080

server {
  port: 8080
  host: "0.0.0.0"
}

// ─── Brand assets (base64-inlined PNGs from the official MX logo) ───────────

let FAVICON_PNG = "data:image/png;base64,"
let LOGO_MARK_PNG = "data:image/png;base64,"

// ─── Routes ──────────────────────────────────────────────────────────────────

get / {
  return html(landing_page())
}

get /status {
  return json({
    site: "mxscript.com",
    served_by: "MX Script",
    repo: "https://github.com/jlkdevelop/mxscript.com",
    language: "https://github.com/jlkdevelop/mxscript",
    creator: "Jassim Alkharafi",
    timestamp: now_iso()
  })
}

// ─── Page composition ────────────────────────────────────────────────────────

fn landing_page() {
  return join([
    "<!DOCTYPE html>",
    "<html lang='en'>",
    head_section(),
    "<body>",
    try_banner(),
    nav_bar(),
    "<main>",
    hero_section(),
    code_demo_section(),
    install_section(),
    features_section(),
    channels_section(),
    about_section(),
    learn_section(),
    get_involved_section(),
    dogfood_callout(),
    "</main>",
    footer_section(),
    runtime_script(),
    "</body>",
    "</html>"
  ], "\n")
}

fn head_section() {
  return join([
    "<head>",
    "  <meta charset='utf-8'>",
    "  <meta name='viewport' content='width=device-width, initial-scale=1'>",
    "  <title>MX Script — a lightweight scripting language for one-file web APIs</title>",
    "  <meta name='description' content='MX Script is a lightweight scripting language for building one-file web APIs. No framework, no build step, no node_modules. Run with mx run app.mx.'>",
    "  <meta name='theme-color' content='#ffffff'>",
    "  <meta property='og:title' content='MX Script'>",
    "  <meta property='og:description' content='A lightweight scripting language for building one-file web APIs.'>",
    "  <meta property='og:url' content='https://mxscript.com'>",
    "  <link rel='icon' type='image/png' href='" + FAVICON_PNG + "'>",
    "  <link rel='apple-touch-icon' href='" + LOGO_MARK_PNG + "'>",
    "  <style>" + styles() + "</style>",
    "</head>"
  ], "\n")
}

fn try_banner() {
  return join([
    "<a class='try-banner' href='https://try.mxscript.com' aria-label='Try MX Script in your browser'>",
    "  <span class='try-pill'>NEW</span>",
    "  <span class='try-text'>Run MX Script in your browser — no install required.</span>",
    "  <span class='try-cta'>Open playground</span>",
    "</a>"
  ], "\n")
}

fn nav_bar() {
  return join([
    "<nav class='nav'>",
    "  <a href='/' class='brand' aria-label='MX Script'>",
    "    <img class='mark' src='" + LOGO_MARK_PNG + "' alt='MX Script'>",
    "  </a>",
    "  <div class='nav-links'>",
    "    <a href='#about'>About</a>",
    "    <a href='https://github.com/jlkdevelop/mxscript#getting-started'>Docs</a>",
    "    <a href='#get-involved'>Get Involved</a>",
    "    <a href='https://github.com/jlkdevelop/mxscript'>GitHub</a>",
    "    <a href='https://github.com/jlkdevelop/mxscript/releases'>Download</a>",
    "    <a href='#help'>Help</a>",
